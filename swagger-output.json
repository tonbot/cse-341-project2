{
  "openapi": "3.0.0",
  "info": {
    "title": "Library API",
    "version": "1.0.0",
    "description": "Swagger documentation for the CSE 341 Project 2 Library API."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development server"
    },
    {
      "url": "https://your-render-service.onrender.com",
      "description": "Published Render API"
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "GitHub OAuth login and session-based authentication"
    },
    {
      "name": "Authors",
      "description": "Create, read, update, and delete authors"
    },
    {
      "name": "Books",
      "description": "Create, read, update, and delete books"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "Check that the Library API is running",
        "description": "",
        "responses": {
          "200": {
            "description": "API welcome message",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "message": "Library API is running",
                    "docs": "/api-docs",
                    "auth": {
                      "login": "/auth/login",
                      "logout": "/auth/logout",
                      "status": "/auth/status",
                      "me": "/auth/me",
                      "protected": "/auth/protected"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Start the GitHub OAuth login flow",
        "description": "Open this route in the browser to sign in with GitHub. On the first successful login, the API creates a user document in MongoDB and then redirects back to /api-docs with a session cookie for protected routes.",
        "responses": {
          "302": {
            "description": "Redirects the browser to GitHub for authentication"
          },
          "503": {
            "description": "Authentication is not configured",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigError"
                }
              }
            }
          }
        }
      }
    },
    "/auth/github/callback": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "GitHub OAuth callback",
        "description": "GitHub redirects back to this route after the user approves login.",
        "responses": {
          "302": {
            "description": "Redirects to Swagger UI after successful authentication"
          },
          "401": {
            "description": "GitHub login failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthenticationError"
                }
              }
            }
          },
          "503": {
            "description": "Service Unavailable"
          }
        }
      }
    },
    "/auth/login-failed": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "GitHub login failure response",
        "description": "",
        "responses": {
          "401": {
            "description": "GitHub login failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthenticationError"
                }
              }
            }
          }
        }
      }
    },
    "/auth/status": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Check the current authentication status",
        "description": "",
        "responses": {
          "200": {
            "description": "Authentication status and current user when logged in",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthStatus"
                }
              }
            }
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Get the currently authenticated user",
        "description": "",
        "responses": {
          "200": {
            "description": "The current logged-in user",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CurrentUserResponse"
                }
              }
            }
          },
          "401": {
            "description": "The request does not include a valid authenticated session",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthenticationError"
                }
              }
            }
          },
          "503": {
            "description": "Authentication is not configured",

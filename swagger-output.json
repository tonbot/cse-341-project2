  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "connect.sid",
        "description": "Session cookie created after a successful GitHub OAuth login at /auth/login."
      }
    },
    "schemas": {
      "UserProfile": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "example": "65f2d87159a6ce95c7bc9999"
          },
          "githubId": {
            "type": "string",
            "example": "123456789"
          },
          "username": {
            "type": "string",
            "example": "octocat"
          },
          "displayName": {
            "type": "string",
            "example": "The Octocat"
